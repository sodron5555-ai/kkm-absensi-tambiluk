# Database (Railway akan otomatis mengisi DATABASE_URL jika kamu attach plugin PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/kkm_absensi?schema=public"

# JWT
JWT_SECRET="ganti_dengan_string_acak_yang_sangat_panjang_dan_rahasia"
JWT_EXPIRES_IN="12h"

# Server
PORT=4000
NODE_ENV=development

# CORS - domain frontend yang diizinkan (pisahkan dengan koma jika lebih dari satu)
CORS_ORIGIN="http://localhost:5173"

# Threshold pencocokan wajah (euclidean distance dari face-api.js)
# Semakin kecil = semakin ketat. Rekomendasi umum: 0.5 - 0.55
FACE_MATCH_THRESHOLD=0.5

# Batas jam absensi default (WIB, format HH:mm) - bisa juga diatur per sesi di database
ABSEN_JAM_MULAI=06:00
ABSEN_JAM_SELESAI=09:00
