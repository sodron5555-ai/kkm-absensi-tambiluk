    "multer": "^2.2.0",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "prisma": "^5.22.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
